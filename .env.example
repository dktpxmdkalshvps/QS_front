# Vercel Frontend Environment Variables
# Vercel > Project > Settings > Environment Variables 에 등록하세요.

# Render FastAPI backend URL 예시:
# NEXT_PUBLIC_API_BASE_URL=https://qs-backend.onrender.com/api
NEXT_PUBLIC_API_BASE_URL=

# 기존 코드 호환용. 둘 중 하나만 설정해도 됩니다.
# NEXT_PUBLIC_API_URL=https://qs-backend.onrender.com/api
